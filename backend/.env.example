# ===== Backend — variáveis de ambiente =====
# Copie para .env e preencha. NUNCA commite o .env real.

# --- Servidor ---
NODE_ENV=development
PORT=3001
# URL do frontend autorizada no CORS (além das já embutidas)
FRONTEND_URL=http://localhost:5173

# --- Supabase ---
SUPABASE_URL=https://<seu-projeto>.supabase.co
SUPABASE_ANON_KEY=<anon-key>
# Service key: SOMENTE no backend. Nunca exponha no frontend.
SUPABASE_SERVICE_KEY=<service-role-key>

# --- Observabilidade (Sprint 4) ---
# Sem SENTRY_DSN, o Sentry fica desligado (no-op). Defina para ativar.
SENTRY_DSN=
# Opcional: identifica a versão nos eventos do Sentry (ex.: git sha)
SENTRY_RELEASE=
# Nível de log do Pino: trace|debug|info|warn|error|fatal (default: info em prod, debug em dev)
LOG_LEVEL=
