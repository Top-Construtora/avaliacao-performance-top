{
  "name": "sistema-gente-gestao",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && npm run dev",
    "frontend": "cd frontend && npm run dev",
    "backend": "cd backend && npm run dev",
    "build": "cd frontend && npm install && npm run build",
    "build:frontend": "cd frontend && npm install && npm run build",
    "build:backend": "cd backend && npm install && npm run build",
    "install:all": "npm install && cd frontend && npm install && cd ../backend && npm install && cd ..",
    "clean": "rm -rf frontend/node_modules backend/node_modules node_modules",
    "clean:install": "npm run clean && npm run install:all",
    "switch-env": "node switch-env.js",
    "lint": "npm --prefix backend run lint && npm --prefix frontend run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md,yml,yaml}\"",
    "prepare": "husky",
    "db:new": "supabase migration new",
    "db:diff": "supabase db diff",
    "db:pull": "supabase db pull",
    "db:push": "supabase db push",
    "db:reset": "supabase db reset",
    "db:lint": "supabase db lint"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.4",
    "supabase": "^2.31.8",
    "vite": "^7.0.6"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Top-Construtora/avaliacao-performance.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Top-Construtora/avaliacao-performance/issues"
  },
  "homepage": "https://github.com/Top-Construtora/avaliacao-performance#readme",
  "description": "",
  "dependencies": {
    "date-fns": "^4.1.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,css,md,yml,yaml}": "prettier --write"
  }
}
